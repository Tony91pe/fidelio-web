generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id          String   @id @default(cuid())
  name        String
  category    String
  description String?
  logo        String?
  address     String
  city        String
  lat         Float?
  lng         Float?
  phone       String?
  website     String?
  primaryColor String? @default("#7C3AED")
  plan        Plan     @default(STARTER)
  paddleCustomerId     String?
  paddleSubscriptionId String?
  billingPortalUrl     String?
  suspended   Boolean  @default(false)
  approved    Boolean  @default(false)
  planExpiresAt DateTime?
  pointsSystem  String   @default("per_visit")
  pointsPerVisit Int     @default(10)
  pointsPerEuro  Float   @default(1.0)
  rewardThreshold Int    @default(100)
  rewardDescription String @default("Premio")
  welcomePoints  Int     @default(50)
  ownerId     String
  ownerEmail  String?
  winbackDays Int      @default(30)
  isFounder   Boolean  @default(false)
  pointsExpireMonths Int?
  slug                      String?  @unique
  emailNotificationsEnabled Boolean @default(true)
  pushNotificationsEnabled  Boolean @default(true)
  birthdayEmailEnabled      Boolean @default(true)
  winbackEmailEnabled       Boolean @default(true)
  onboardingCompleted       Boolean @default(false)
  customers   Customer[]
  rewards     Reward[]
  giftCards   GiftCard[]
  campaigns   Campaign[]
  visits      Visit[]
  offers      Offer[]
  staff       StaffMember[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StaffMember {
  id        String    @id @default(cuid())
  shopId    String
  shop      Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name      String
  email     String
  role      StaffRole @default(COMMESSO)
  createdAt DateTime  @default(now())
  @@unique([email, shopId])
}

enum StaffRole {
  COMMESSO
  MANAGER
}

model Customer {
  id           String    @id @default(cuid())
  email        String
  name         String
  code         String    @unique @default(cuid())
  phone        String?
  birthday     DateTime?
  points       Int       @default(0)
  totalVisits  Int       @default(0)
  lastVisitAt  DateTime?
  unsubscribed Boolean   @default(false)
  pointsExpiresAt DateTime?
  referralCode String?   @unique
  referredBy   String?
  shopId       String?
  shop         Shop?     @relation(fields: [shopId], references: [id])
  visits       Visit[]
  redemptions  Redemption[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([email, shopId])
}

model Visit {
  id         String   @id @default(cuid())
  points     Int
  amount     Float?
  note       String?
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id])
  createdAt  DateTime @default(now())
}

model Reward {
  id          String       @id @default(cuid())
  title       String
  description String?
  pointsCost  Int
  active      Boolean      @default(true)
  shopId      String
  shop        Shop         @relation(fields: [shopId], references: [id])
  redemptions Redemption[]
  createdAt   DateTime     @default(now())
}

model Redemption {
  id         String   @id @default(cuid())
  points     Int
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  rewardId   String
  reward     Reward   @relation(fields: [rewardId], references: [id])
  createdAt  DateTime @default(now())
}

model Campaign {
  id        String         @id @default(cuid())
  type      CampaignType
  subject   String
  body      String
  status    CampaignStatus @default(DRAFT)
  sentAt    DateTime?
  shopId    String
  shop      Shop           @relation(fields: [shopId], references: [id])
  createdAt DateTime       @default(now())
}

model GiftCard {
  id            String    @id @default(cuid())
  code          String    @unique
  points        Int       @default(0)
  value         Float?
  description   String?
  dedica        String?
  customerEmail String?
  customerName  String?
  remainingValue Float?
  used          Boolean   @default(false)
  usedAt        DateTime?
  shopId        String
  shop          Shop      @relation(fields: [shopId], references: [id])
  createdAt     DateTime  @default(now())
}

model Offer {
  id          String    @id @default(cuid())
  title       String
  description String
  expiresAt   DateTime?
  active      Boolean   @default(true)
  shopId      String
  shop        Shop      @relation(fields: [shopId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expires   DateTime
  type      String   @default("customer")
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([email, type])
}

model PushSubscription {
  id        String   @id @default(cuid())
  email     String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([email])
}


enum Plan {
  STARTER
  GROWTH
  PRO
}

enum CampaignType {
  WELCOME
  BIRTHDAY
  WINBACK
  REWARD_AVAILABLE
  MANUAL
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
}
model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  category    String
  readTime    String   @default("5 min")
  content     String
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String
  text      String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Affiliate {
  id               String              @id @default(cuid())
  name             String
  email            String
  code             String              @unique
  commissionType   CommissionType      @default(MONTHLY)
  commissionAmount Float               @default(0)
  commissionMonths Int                 @default(0)
  active           Boolean             @default(true)
  notes            String?
  referrals        AffiliateReferral[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model AffiliateReferral {
  id              String    @id @default(cuid())
  affiliateId     String
  affiliate       Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  shopId          String    @unique
  commissionPaid  Boolean   @default(false)
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
}

enum CommissionType {
  MONTHLY
  ONE_TIME
}

model Log {
  id        String   @id @default(cuid())
  eventType String
  userId    String?
  shopId    String?
  customerId String?
  action    String
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@index([userId])
  @@index([createdAt])
  @@index([eventType])
}
